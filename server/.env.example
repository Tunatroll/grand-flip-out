# Copy to .env for local dev. Do not commit .env.
PORT=3000
JWT_SECRET=your-long-random-secret-at-least-32-chars
API_RATE_LIMIT=60

# Optional: Postgres (when set, server uses store-pg.js)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: Stripe (payments). See docs/PAYMENTS.md.
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# BASE_URL=https://grandflipout.com

# Optional: Discord bot (server/scripts/discord-bot.js). See docs/DISCORD.md.
# DISCORD_BOT_TOKEN=...
# API_BASE_URL=https://grandflipout.com
